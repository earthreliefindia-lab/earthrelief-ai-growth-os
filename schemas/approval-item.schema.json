{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "Approval Item",
  "type": "object",
  "required": ["type", "suggestion", "reason", "expected_impact", "risk", "confidence", "status"],
  "properties": {
    "type": { "type": "string", "enum": ["social_content", "seo_suggestion", "website_change", "workflow_action"] },
    "suggestion": { "type": "string" },
    "reason": { "type": "string" },
    "expected_impact": { "type": "string" },
    "risk": { "type": "string", "enum": ["low", "medium", "high"] },
    "confidence": { "type": "number", "minimum": 0, "maximum": 100 },
    "status": { "type": "string", "enum": ["pending", "approved", "rejected", "modify_requested"] },
    "platform": { "type": "string" },
    "created_at": { "type": "string" },
    "notes": { "type": "string" }
  }
}
